# Copy to .env.local. For LOCAL Supabase, run `npm run db:status` to get live values.
# Defaults below match the local stack defined in supabase/config.toml (API on 55521).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:55521"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key from: npm run db:status>"
SUPABASE_SERVICE_ROLE_KEY="<service_role key from: npm run db:status>"  # server-only, never expose to client

# Optional integration keys (stubs ship API-ready; fill to go live)
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
TELEPHONY_PROVIDER=""        # myoperator | mcube | exotel | knowlarity
TELEPHONY_API_KEY=""
SMTP_HOST=""
SMTP_USER=""
SMTP_PASS=""
META_LEADS_VERIFY_TOKEN=""

# Freddy-style AI insights on the lead record (server-side). Without it the panel
# falls back to deterministic heuristics, so the app still works offline.
ANTHROPIC_API_KEY=""
